<div class="post-layout">
  <article class="content-card post-card reveal">
    <header class="post-header">
      <div class="article-meta">
        <span><%= date(page.date, 'YYYY-MM-DD') %></span>
        <% if (page.categories && page.categories.length) { %>
          <span><%= page.categories.map((cat) => cat.name).join(' / ') %></span>
        <% } %>
        <span><%= wordcount(page.content || '') %> Words</span>
        <span><%= min2read(page.content || '') %> Min Read</span>
      </div>
      <h1><%= page.title %></h1>
      <% if (page.tags && page.tags.length) { %>
        <div class="article-tags post-tags">
          <% page.tags.forEach((tag) => { %>
            <a href="<%- url_for(tag.path) %>"><%= tag.name %></a>
          <% }) %>
        </div>
      <% } %>
    </header>
    <div class="post-content">
      <%- page.content %>
    </div>
  </article>

  <aside class="content-card post-toc reveal" id="postTocCard" aria-label="文章目录">
    <div class="post-toc-title">On This Page</div>
    <nav class="post-toc-list" id="postToc"></nav>
  </aside>

  <% if (config.lucian.comments && config.lucian.comments.enable && config.lucian.comments.provider === 'utterances') { %>
    <section class="content-card comments-card reveal">
      <h2>Comments</h2>
      <div class="comments-note">评论由 GitHub Issues 驱动。首次使用时可能需要安装或授权 utterances。</div>
      <script src="https://utteranc.es/client.js"
        id="utterancesScript"
        repo="<%= config.lucian.comments.repo %>"
        issue-term="<%= config.lucian.comments.issue_term %>"
        label="<%= config.lucian.comments.label %>"
        theme="<%= config.lucian.comments.theme %>"
        crossorigin="anonymous"
        async>
      </script>
    </section>
  <% } %>
</div>
