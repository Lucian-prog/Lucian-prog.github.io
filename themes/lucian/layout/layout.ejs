<!DOCTYPE html>
<html lang="<%= config.language || 'zh-CN' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= page.title ? `${page.title} | ${config.title}` : config.title %></title>
  <meta name="description" content="<%= page.excerpt ? strip_html(page.excerpt).trim() : config.description %>">
  <link rel="icon" href="/images/avatar.png" type="image/png">
  <script>
    (() => {
      const themeKey = 'lucian-color-theme';
      const fallbackTheme = 'claude-light';
      try {
        document.documentElement.dataset.theme = localStorage.getItem(themeKey) || fallbackTheme;
      } catch (error) {
        document.documentElement.dataset.theme = fallbackTheme;
      }
    })();
  </script>
  <script>
    (() => {
      const resetKey = 'lucian-sw-cache-reset-v2';
      const clearLegacyCache = async () => {
        try {
          if ('serviceWorker' in navigator) {
            const registrations = await navigator.serviceWorker.getRegistrations();
            await Promise.all(registrations.map((registration) => registration.unregister()));
          }

          if ('caches' in window) {
            const keys = await caches.keys();
            await Promise.all(keys.map((key) => caches.delete(key)));
          }

          if (navigator.serviceWorker?.controller && !sessionStorage.getItem(resetKey)) {
            sessionStorage.setItem(resetKey, '1');
            window.location.reload();
          }
        } catch (error) {
          console.warn('Legacy cache cleanup skipped:', error);
        }
      };

      clearLegacyCache();
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <%# 精简字重：英文/代码/中文各保留实际用到的字重，砍掉冗余，显著减小字体下载体积 %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;700&family=Noto+Sans+SC:wght@400;500;700&family=Noto+Serif+SC:wght@400;500;700&display=swap" rel="stylesheet">
  <%# KaTeX CSS 仅在文章 front-matter 声明 math: true 时注入，避免全站加载 %>
  <% if (page.math) { %><link rel="stylesheet" href="/vendor/katex/katex.min.css"><% } %>
  <%- css('/css/style.css') %>
</head>
<body>
  <div class="site-loader" aria-hidden="true">
    <div class="loader-clock">
      <span></span>
    </div>
    <div class="loader-text">女仆整理时间轴中...</div>
  </div>

  <nav class="top-nav">
    <a class="nav-logo" href="/"><%= config.lucian.hero.logo %></a>
    <div class="nav-actions">
      <button class="search-toggle" type="button" aria-label="打开全局搜索" aria-haspopup="dialog" aria-expanded="false">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
      </button>
      <div class="theme-switcher">
        <button class="theme-toggle" type="button" aria-label="切换主题配色" aria-expanded="false">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"></path></svg>
        </button>
        <div class="theme-menu" role="menu" aria-label="主题配色">
          <button type="button" data-theme-choice="claude-light" role="menuitem">
            <span class="theme-swatch theme-swatch-claude-light"></span>Claude Light
          </button>
          <button type="button" data-theme-choice="claude-dark" role="menuitem">
            <span class="theme-swatch theme-swatch-claude-dark"></span>Claude Dark
          </button>
          <button type="button" data-theme-choice="scarlet" role="menuitem">
            <span class="theme-swatch theme-swatch-scarlet"></span>Scarlet
          </button>
          <button type="button" data-theme-choice="midnight" role="menuitem">
            <span class="theme-swatch theme-swatch-midnight"></span>Midnight
          </button>
          <button type="button" data-theme-choice="paper" role="menuitem">
            <span class="theme-swatch theme-swatch-paper"></span>Paper
          </button>
          <button type="button" data-theme-choice="pixel" role="menuitem">
            <span class="theme-swatch theme-swatch-pixel"></span>Pixel
          </button>
          <button type="button" data-theme-choice="terminal" role="menuitem">
            <span class="theme-swatch theme-swatch-terminal"></span>Terminal
          </button>
        </div>
      </div>
      <button class="nav-toggle" aria-label="打开导航" aria-expanded="false">☰</button>
      <div class="nav-links">
        <% config.lucian.nav.forEach((item) => { %>
          <a href="<%= item.url %>"><%= item.name %></a>
        <% }) %>
      </div>
    </div>
  </nav>

  <main class="container">
    <%- body %>
  </main>

  <section class="search-overlay" aria-hidden="true">
    <div class="search-panel" role="dialog" aria-modal="true" aria-labelledby="searchTitle">
      <div class="search-panel-header">
        <div>
          <p class="search-kicker">Global Search</p>
          <h2 id="searchTitle">检索笔记</h2>
        </div>
        <button class="search-close" type="button" aria-label="关闭搜索">×</button>
      </div>
      <label class="search-input-wrap">
        <span>Keyword</span>
        <input id="siteSearchInput" type="search" autocomplete="off" placeholder="搜索 RISC-V、FIFO、APB、流水线..." />
      </label>
      <div class="search-status" id="siteSearchStatus">输入关键词后，将从标题、标签、分类和正文中检索。</div>
      <div class="search-results" id="siteSearchResults"></div>
    </div>
  </section>

  <footer class="site-footer">
    <span>© <%= date(new Date(), 'YYYY') %> Lucian</span>
    <span>Powered by Hexo · Theme Lucian</span>
  </footer>

  <button class="back-to-top" type="button" aria-label="返回顶部">
    <span></span>
  </button>

  <script>
    window.LUCIAN_FEATURES = <%- JSON.stringify(config.lucian || {}) %>;
  </script>
  <%- js('/js/main.js') %>
</body>
</html>
