<%
  const legacyProgress = config.lucian.main_thread || {};
  const publishedProgress = site.data && site.data.progress
    ? site.data.progress
    : {
      title: legacyProgress.title || '学习主线',
      chapters: Array.isArray(legacyProgress.outline)
        ? legacyProgress.outline.map((item) => ({
          title: item.title,
          progress: ['done', 'complete', 'completed', true].includes(item.status) ? 100 : 0
        }))
        : []
    };
  const publishedProgressJson = JSON.stringify(publishedProgress).replace(/</g, '\\u003c');
%>

<section class="content-card editor-page reveal">
  <header class="editor-header">
    <div>
      <p class="editor-kicker">Local Workspace</p>
      <h1>写作与学习管理</h1>
      <p>文章草稿和学习主线均保存在当前浏览器中。</p>
    </div>
  </header>

  <div class="editor-tabs" role="tablist" aria-label="写作工具">
    <button class="editor-tab is-active" type="button" role="tab" aria-selected="true" aria-controls="editorDraftPanel" data-editor-tab="drafts">文章草稿</button>
    <button class="editor-tab" type="button" role="tab" aria-selected="false" aria-controls="editorProgressPanel" data-editor-tab="progress">学习进度</button>
  </div>

  <section class="editor-view is-active" id="editorDraftPanel" role="tabpanel" data-editor-view="drafts">
    <div class="editor-actions editor-view-actions">
      <button class="editor-button" type="button" data-editor-action="new">新建草稿</button>
      <button class="editor-button" type="button" data-editor-action="save">保存草稿</button>
      <button class="editor-button editor-button-danger" type="button" data-editor-action="delete">删除草稿</button>
      <button class="editor-button" type="button" data-editor-action="copy">复制 Markdown</button>
      <button class="editor-button" type="button" data-editor-action="download">下载 .md</button>
      <button class="editor-button editor-button-primary" type="button" data-editor-action="export">导出文章包</button>
    </div>

    <div class="editor-shell">
      <aside class="draft-box">
        <div class="draft-box-header">
          <div>
            <span>Drafts</span>
            <strong id="draftCount">0</strong>
          </div>
          <button class="draft-mini-button" type="button" data-editor-action="new" aria-label="新建草稿" title="新建草稿">+</button>
        </div>
        <div class="draft-list" id="draftList" aria-label="草稿列表"></div>
      </aside>

      <div class="editor-workspace">
        <form class="editor-form" autocomplete="off">
          <label>
            <span>标题</span>
            <input id="draftTitle" type="text" value="新的学习笔记">
          </label>
          <label>
            <span>Slug / 文件名</span>
            <input id="draftSlug" type="text" value="new-learning-note">
          </label>
          <label>
            <span>主分类</span>
            <input id="draftCategories" type="text" value="Reading Notes">
          </label>
          <label>
            <span>标签</span>
            <input id="draftTags" type="text" value="digital-design, systemverilog, verilog">
          </label>
          <label class="editor-wide">
            <span>摘要</span>
            <textarea id="draftExcerpt" rows="3">记录一个具体问题、核心结论和后续复盘方向。</textarea>
          </label>
        </form>

        <div class="composer-tabs" role="tablist" aria-label="编辑与预览">
          <button class="composer-tab is-active" type="button" role="tab" aria-selected="true" data-composer-tab="write">编辑</button>
          <button class="composer-tab" type="button" role="tab" aria-selected="false" data-composer-tab="preview">预览</button>
        </div>

        <div class="editor-composer">
          <section class="composer-pane composer-write-pane is-active" data-composer-pane="write">
            <div class="markdown-toolbar" role="toolbar" aria-label="Markdown 格式工具">
              <button type="button" data-markdown-command="h2" title="二级标题" aria-label="插入二级标题">H2</button>
              <button type="button" data-markdown-command="h3" title="三级标题" aria-label="插入三级标题">H3</button>
              <span class="toolbar-divider" aria-hidden="true"></span>
              <button type="button" data-markdown-command="bold" title="粗体（Ctrl+B）" aria-label="加粗"><strong>B</strong></button>
              <button type="button" data-markdown-command="italic" title="斜体（Ctrl+I）" aria-label="斜体"><em>I</em></button>
              <button type="button" data-markdown-command="quote" title="引用" aria-label="插入引用">❯</button>
              <button type="button" data-markdown-command="ul" title="无序列表" aria-label="插入无序列表">• List</button>
              <button type="button" data-markdown-command="ol" title="有序列表" aria-label="插入有序列表">1. List</button>
              <span class="toolbar-divider" aria-hidden="true"></span>
              <button type="button" data-markdown-command="inline-code" title="行内代码" aria-label="插入行内代码">&lt;/&gt;</button>
              <button type="button" data-markdown-command="code" title="代码块" aria-label="插入代码块">{ }</button>
              <button type="button" data-markdown-command="link" title="链接（Ctrl+K）" aria-label="插入链接">Link</button>
              <button type="button" data-markdown-command="table" title="表格" aria-label="插入表格">Table</button>
              <button type="button" data-markdown-command="math" title="LaTeX 公式" aria-label="插入 LaTeX 公式">∑</button>
              <button class="toolbar-image-button" type="button" data-markdown-command="image" title="插入图片" aria-label="插入图片">Image +</button>
            </div>

            <div class="markdown-editor-frame" id="draftDropZone">
              <label class="editor-body-label" for="draftBody">正文 Markdown</label>
              <textarea id="draftBody" rows="24" spellcheck="false">## 问题背景

这里记录学习动机、章节来源和核心问题。

## 硬件结构

- 信号流：
- 时序关系：
- 边界条件：

```verilog
module example (
  input  wire clk,
  input  wire rst_n
);
endmodule
```

## 复盘

这里整理仿真结果、波形观察和后续问题。</textarea>
              <div class="image-drop-overlay" aria-hidden="true">
                <strong>释放图片以插入</strong>
                <span>PNG · JPEG · WebP · GIF，单图不超过 20 MiB</span>
              </div>
            </div>

            <div class="composer-statusbar">
              <span id="draftEditorStats">0 字 · 0 行</span>
              <strong id="draftStatus" role="status" aria-live="polite">已同步</strong>
            </div>

            <section class="asset-shelf" aria-labelledby="assetShelfTitle">
              <div class="asset-shelf-header">
                <div>
                  <span>Image Assets</span>
                  <strong id="assetShelfTitle">文章图片</strong>
                </div>
                <div class="asset-shelf-actions">
                  <span id="assetSummary">0 张 · 0 B</span>
                  <button class="editor-button" type="button" data-image-action="choose">选择图片</button>
                </div>
              </div>
              <input id="draftImageInput" type="file" accept="image/png,image/jpeg,image/webp,image/gif" multiple hidden>
              <div class="asset-list" id="draftAssetList"></div>
              <p class="asset-empty" id="draftAssetEmpty">可直接粘贴截图、拖入图片，或从本地选择文件。</p>
            </section>
          </section>

          <aside class="editor-output composer-pane" data-composer-pane="preview">
            <div class="editor-output-header preview-heading">
              <span>实时预览</span>
              <strong id="draftFilename">new-learning-note.md</strong>
            </div>
            <div class="editor-preview post-content" id="draftPreview"></div>

            <details class="markdown-output-details">
              <summary>查看完整 Markdown 输出</summary>
              <textarea id="draftMarkdown" rows="13" readonly></textarea>
            </details>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <section class="editor-view" id="editorProgressPanel" role="tabpanel" data-editor-view="progress" hidden>
    <div class="editor-actions editor-view-actions">
      <button class="editor-button" type="button" data-progress-action="reset">恢复线上数据</button>
      <button class="editor-button" type="button" data-progress-action="copy">复制 YAML</button>
      <button class="editor-button editor-button-primary" type="button" data-progress-action="download">下载 progress.yml</button>
    </div>

    <div class="progress-manager-grid">
      <div class="progress-manager-form">
        <label class="progress-title-field">
          <span>学习主线标题</span>
          <input id="progressTitle" type="text" autocomplete="off">
        </label>

        <div class="progress-manager-heading">
          <div>
            <span>章节</span>
            <strong id="progressChapterCount">0</strong>
          </div>
          <button class="editor-button" type="button" data-progress-action="add">新增章节</button>
        </div>

        <div class="progress-chapter-list" id="progressChapterList"></div>
        <div class="progress-manager-status" id="progressManagerStatus" role="status">已载入线上数据</div>
      </div>

      <aside class="progress-manager-output">
        <div class="progress-preview-card">
          <div class="progress-preview-header">
            <span>总体进度</span>
            <strong id="progressOverall">0%</strong>
          </div>
          <div class="progress-preview-track" aria-hidden="true">
            <span id="progressPreviewFill"></span>
          </div>
          <div class="progress-preview-counts">
            <span><strong id="progressDoneCount">0</strong> 已完成</span>
            <span><strong id="progressDoingCount">0</strong> 进行中</span>
            <span><strong id="progressTodoCount">0</strong> 未开始</span>
          </div>
          <div class="progress-preview-next">
            <span>Next Step</span>
            <strong id="progressNextStep">等待补充章节</strong>
          </div>
        </div>

        <div class="editor-output-header">
          <span>progress.yml</span>
          <strong id="progressOutputStatus">可导出</strong>
        </div>
        <textarea id="progressYaml" rows="18" readonly></textarea>
      </aside>
    </div>
  </section>
</section>

<script id="publishedProgressData" type="application/json"><%- publishedProgressJson %></script>
<script src="/vendor/marked/marked.umd.js"></script>
<script src="/vendor/dompurify/purify.min.js"></script>
<script src="/vendor/jszip/jszip.min.js"></script>
<script src="/vendor/katex/katex.min.js"></script>
<script src="/vendor/katex/contrib/auto-render.min.js"></script>
<script src="/js/editor.js"></script>
