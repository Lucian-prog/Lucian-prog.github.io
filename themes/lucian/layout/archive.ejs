<section class="content-card list-page">
  <h1><%= page.archive ? '归档' : page.title || '归档' %></h1>
  <div class="archive-list">
    <% page.posts.sort('-date').forEach((post) => { %>
      <a class="archive-item" href="<%- url_for(post.path) %>">
        <time><%= date(post.date, 'YYYY-MM-DD') %></time>
        <span><%= post.title %></span>
      </a>
    <% }) %>
  </div>
</section>
