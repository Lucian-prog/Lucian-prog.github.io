<%
  const posts = site.posts.sort('-date');
  const latestPosts = posts.limit(5);
  const postCount = posts.length;
  const categoryCount = site.categories.length;
  const tagCount = site.tags.length;
  const mainThread = config.lucian.main_thread || {};
  const outline = Array.isArray(mainThread.outline) ? mainThread.outline : [];
  const isDone = (item) => ['done', 'complete', 'completed', true].includes(item && item.status);
  const doneCount = outline.filter(isDone).length;
  const threadProgress = outline.length
    ? Math.round((doneCount / outline.length) * 100)
    : Number(mainThread.progress || 0);
  const latestPost = latestPosts.first();
  const nextOutline = outline.find((item) => !isDone(item));
  const recentLabel = latestPost ? latestPost.title : (mainThread.recent || '暂无已发布笔记');
  const recentUrl = latestPost ? url_for(latestPost.path) : '';
  const nextLabel = nextOutline ? nextOutline.title : (outline.length ? '当前大纲已完成' : (mainThread.next || '等待补充大纲'));
%>

<header class="portal-card reveal">
  <div class="portal-mark" aria-hidden="true">⚙</div>
  <div class="avatar-container">
    <img class="avatar" src="<%= config.lucian.hero.avatar %>" alt="Lucian avatar">
  </div>
  <h1 class="site-title"><%= config.lucian.hero.title %></h1>
  <p class="site-desc-en"><%= config.lucian.hero.subtitle %></p>
  <p class="site-desc-cn"><%= config.lucian.hero.description %></p>

  <div class="stats-group">
    <div class="stat-item"><span class="stat-num"><%= postCount %></span><span class="stat-label">Articles</span></div>
    <div class="stat-item"><span class="stat-num"><%= categoryCount %></span><span class="stat-label">Categories</span></div>
    <div class="stat-item"><span class="stat-num"><%= tagCount %></span><span class="stat-label">Tags</span></div>
  </div>
</header>

<h2 class="section-title">Knowledge Matrix</h2>
<section class="topics-grid">
  <% config.lucian.topics.forEach((topic) => { %>
    <a class="topic-card reveal" href="<%= topic.url %>">
      <div class="topic-title"><%= topic.title %></div>
      <div class="topic-desc"><%= topic.desc %></div>
    </a>
  <% }) %>
</section>

<h2 class="section-title">Current Main Thread</h2>
<section class="learning-thread reveal">
  <div class="thread-header">
    <div class="thread-title"><%= mainThread.title %></div>
    <div class="thread-status">Progress: <%= threadProgress %>%</div>
  </div>
  <div class="progress-track" aria-label="reading progress">
    <div class="progress-fill" style="width: <%= Math.max(0, Math.min(threadProgress, 100)) %>%"></div>
  </div>
  <div class="thread-details">
    <% if (recentUrl) { %>
      <a class="detail-tag" href="<%- recentUrl %>"><span>近期更新</span><%= recentLabel %></a>
    <% } else { %>
      <div class="detail-tag"><span>近期更新</span><%= recentLabel %></div>
    <% } %>
    <div class="detail-tag"><span>Next Step</span><%= nextLabel %></div>
    <% if (outline.length) { %>
      <div class="detail-tag"><span>Outline</span><%= doneCount %> / <%= outline.length %></div>
    <% } %>
  </div>
</section>

<h2 class="section-title">Latest Notes</h2>
<section class="article-list">
  <% latestPosts.forEach((post) => { %>
    <article class="article-card reveal">
      <div class="article-meta">
        <span><%= date(post.date, 'YYYY-MM-DD') %></span>
        <% if (post.categories && post.categories.length) { %>
          <span><%= post.categories.map((cat) => cat.name).join(' / ') %></span>
        <% } %>
        <span><%= wordcount(post.content || '') %> Words</span>
        <span><%= min2read(post.content || '') %> Min Read</span>
      </div>
      <h3 class="article-title"><a href="<%- url_for(post.path) %>"><%= post.title %></a></h3>
      <p class="article-excerpt"><%= strip_html(post.excerpt || post.content).replace(/\s+/g, ' ').slice(0, 180) %>...</p>
      <div class="article-footer">
        <div class="article-tags">
          <% if (post.tags) { post.tags.limit(4).forEach((tag) => { %>
            <a href="<%- url_for(tag.path) %>"><%= tag.name %></a>
          <% }) } %>
        </div>
        <a href="<%- url_for(post.path) %>" class="read-more">Read More »</a>
      </div>
    </article>
  <% }) %>
</section>

<h2 class="section-title">Projects & Labs</h2>
<section class="projects-grid">
  <% config.lucian.projects.forEach((project) => { %>
    <a class="project-chip reveal" href="<%= project.url %>"><%= project.title %></a>
  <% }) %>
</section>
